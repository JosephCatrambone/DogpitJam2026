offset_bottom = 292.0
bbcode_enabled = true
text = "
Players take turns.

On your turn, place a creature on the board.

If any row, column, or diagonal contains all the same traits (all smol, all cat, all zoomy, etc), you lose.

After you have placed the creature, if you have not lost, select a creature for your opponent to place.
"
fit_content = true

